    {
      "question": "What are all classes, object properties, and datatype properties defined in the Cisco Bookings Enterprise Ontology, along with their labels and comments?",
      "sparql": "PREFIX : <http://example.org/cisco/bookings-ontology#>\nPREFIX owl: <http://www.w3.org/2002/07/owl#>\nPREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>\nPREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\nPREFIX skos: <http://www.w3.org/2004/02/skos/core#>\nPREFIX xsd: <http://www.w3.org/2001/XMLSchema#>\n\nSELECT ?entity ?type ?label ?comment\nWHERE {\n  { ?entity a owl:Class . }\n  UNION\n  { ?entity a owl:ObjectProperty . }\n  UNION\n  { ?entity a owl:DatatypeProperty . }\n  OPTIONAL { ?entity rdfs:label ?label . }\n  OPTIONAL { ?entity rdfs:comment ?comment . }\n  BIND(\n    IF(EXISTS { ?entity a owl:Class }, \"Class\",\n      IF(EXISTS { ?entity a owl:ObjectProperty }, \"ObjectProperty\",\n        IF(EXISTS { ?entity a owl:DatatypeProperty }, \"DatatypeProperty\", \"Other\")\n      )\n    ) AS ?type\n  )\n}\nORDER BY ?type ?entity"
    },
    {
      "question": "What is the class hierarchy, showing each class and its direct superclass defined in the ontology?",
      "sparql": "PREFIX : <http://example.org/cisco/bookings-ontology#>\nPREFIX owl: <http://www.w3.org/2002/07/owl#>\nPREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>\nPREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\nPREFIX skos: <http://www.w3.org/2004/02/skos/core#>\nPREFIX xsd: <http://www.w3.org/2001/XMLSchema#>\n\nSELECT ?class ?classLabel ?superClass ?superClassLabel\nWHERE {\n  ?class a owl:Class .\n  ?class rdfs:subClassOf ?superClass .\n  FILTER(isIRI(?superClass))\n  OPTIONAL { ?class rdfs:label ?classLabel . }\n  OPTIONAL { ?superClass rdfs:label ?superClassLabel . }\n}\nORDER BY ?superClass ?class"
    },
    {
      "question": "Which booking transaction individuals exist, and what are their booking IDs and booking amounts in USD?",
      "sparql": "PREFIX : <http://example.org/cisco/bookings-ontology#>\nPREFIX owl: <http://www.w3.org/2002/07/owl#>\nPREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>\nPREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\nPREFIX skos: <http://www.w3.org/2004/02/skos/core#>\nPREFIX xsd: <http://www.w3.org/2001/XMLSchema#>\n\nSELECT ?booking ?bookingId ?bookingAmount\nWHERE {\n  ?booking a :BookingTransactionFact .\n  OPTIONAL { ?booking :bookingId ?bookingId . }\n  OPTIONAL { ?booking :bookingAmountUSD ?bookingAmount . }\n}\nORDER BY ?booking"
    },
    {
      "question": "For each booking transaction, which customer, product, partner, sales representative, contract, and geography are linked via object properties?",
      "sparql": "PREFIX : <http://example.org/cisco/bookings-ontology#>\nPREFIX owl: <http://www.w3.org/2002/07/owl#>\nPREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>\nPREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\nPREFIX skos: <http://www.w3.org/2004/02/skos/core#>\nPREFIX xsd: <http://www.w3.org/2001/XMLSchema#>\n\nSELECT ?booking ?customer ?product ?partner ?salesRep ?contract ?geography\nWHERE {\n  ?booking a :BookingTransactionFact .\n  OPTIONAL { ?booking :placedByCustomer ?customer . }\n  OPTIONAL { ?booking :includesProduct ?product . }\n  OPTIONAL { ?booking :involvesPartner ?partner . }\n  OPTIONAL { ?booking :ownedBySalesRepresentative ?salesRep . }\n  OPTIONAL { ?booking :classifiedByContract ?contract . }\n  OPTIONAL { ?booking :classifiedByGeography ?geography . }\n}\nORDER BY ?booking"
    },
    {
      "question": "What key financial and descriptive measures (booking amount, total contract value, annual contract value, discount percentage, quantity sold, and booking type) are recorded for each booking transaction?",
      "sparql": "PREFIX : <http://example.org/cisco/bookings-ontology#>\nPREFIX owl: <http://www.w3.org/2002/07/owl#>\nPREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>\nPREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\nPREFIX skos: <http://www.w3.org/2004/02/skos/core#>\nPREFIX xsd: <http://www.w3.org/2001/XMLSchema#>\n\nSELECT ?booking ?bookingAmount ?totalContractValue ?annualContractValue ?discountPct ?quantitySold ?bookingType\nWHERE {\n  ?booking a :BookingTransactionFact .\n  OPTIONAL { ?booking :bookingAmountUSD ?bookingAmount . }\n  OPTIONAL { ?booking :totalContractValueUSD ?totalContractValue . }\n  OPTIONAL { ?booking :annualContractValueUSD ?annualContractValue . }\n  OPTIONAL { ?booking :discountPercentage ?discountPct . }\n  OPTIONAL { ?booking :quantitySold ?quantitySold . }\n  OPTIONAL { ?booking :bookingType ?bookingType . }\n}\nORDER BY ?booking"
